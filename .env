# ─────────────────────────────────────────────────────────────────────────────
# Локальный .env (НЕ коммитится — под **/.env в .gitignore).
# GROQ_API_KEY действующий. Если он попадёт в публичный репозиторий или логи —
# немедленно ротируйте на https://console.groq.com/keys.
# ─────────────────────────────────────────────────────────────────────────────

BELPOMOSHNIK_SECRET_KEY=replace-me-with-output-of-python-secrets-token-hex-32

# MySQL — единственная поддерживаемая СУБД (с версии 2026-06-11).
# Поднимите MySQL через docker-compose: docker compose up -d mysql
BELPOMOSHNIK_DATABASE_URL=mysql+pymysql://root:belp_root@127.0.0.1:3306/belpomoshnik?charset=utf8mb4
BELPOMOSHNIK_ENABLE_TEST_SWITCHER=true

GROQ_API_KEY=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
GROQ_MODEL=llama-3.1-8b-instant
