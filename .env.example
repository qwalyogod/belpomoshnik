# ─────────────────────────────────────────────────────────────────────────────
# Белпомощник — переменные окружения backend
# ─────────────────────────────────────────────────────────────────────────────
# Скопируйте в .env и заполните:
#   cp .env.example .env
#   # Сгенерируйте 32+ символов:
#   python -c "import secrets; print(secrets.token_hex(32))"
#
# Backend не стартует без BELPOMOSHNIK_SECRET_KEY (fail-fast в auth.py).

# ОБЯЗАТЕЛЬНО: 32+ символов, уникальный.
BELPOMOSHNIK_SECRET_KEY=

# БД: MySQL 8 (единственная поддерживаемая СУБД).
#   mysql+pymysql://USER:PASSWORD@HOST:PORT/DATABASE?charset=utf8mb4
# По умолчанию — локальный MySQL из docker-compose (см. docker-compose.yml):
#   user=root password=belp_root db=belpomoshnik
BELPOMOSHNIK_DATABASE_URL=mysql+pymysql://root:belp_root@127.0.0.1:3306/belpomoshnik?charset=utf8mb4

# Директория загрузок (аватары, обложки статей, сканы документов).
# По умолчанию — <корень проекта>/data/uploads.
# BELPOMOSHNIK_UPLOAD_DIR=/var/lib/belpomoshnik/uploads

# JWT
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Demo-режим (см. PROJECT_STATUS.md). Включает /api/auth/test-accounts
# и автоматически создаёт тест-аккаунты при bootstrap. В production — false.
BELPOMOSHNIK_ENABLE_TEST_SWITCHER=true

# AI-ассистент (Groq). Без ключа ассистент работает в локальном canned-режиме.
GROQ_API_KEY=replace-me
GROQ_MODEL=llama-3.1-8b-instant

# Email (SMTP). Если SMTP_USER/SMTP_PASSWORD пустые — соединяется без AUTH
# (полезно для dev-релеев вроде MailHog). Без SMTP_* email'ы уходят в очередь.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@belpomoshnik.local
SMTP_TLS=true

# Bootstrap admin. Если заданы BELPOMOSHNIK_ADMIN_EMAIL/PASSWORD — при bootstrap
# создаётся пользователь с ролью platform_admin (идемпотентно).
BELPOMOSHNIK_ADMIN_EMAIL=
BELPOMOSHNIK_ADMIN_PASSWORD=

# Frontend: см. reactvitemaket/.env.example
# Обычно достаточно:  VITE_API_BASE_URL=http://127.0.0.1:8060
